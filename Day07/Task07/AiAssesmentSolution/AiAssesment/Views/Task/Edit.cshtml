@model AiAssesment.Domain.Entities.TaskItem

@{
    ViewData["Title"] = "Edit Task";
    bool isOverdue = !Model.IsCompleted && Model.DueDate.HasValue && Model.DueDate.Value.Date < DateTime.Today;
}

<style>
    .form-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .breadcrumb-nav { font-size: .82rem; color: #64748b; display: flex; align-items: center; gap: .4rem; }
    .breadcrumb-nav a { color: #6366f1; text-decoration: none; }
    .breadcrumb-nav a:hover { text-decoration: underline; }
    .page-title-row h1 {
        font-size: 1.5rem; font-weight: 700; color: #0f172a; margin: 0;
        display: flex; align-items: center; gap: .5rem;
    }
    .page-title-row h1 .title-icon {
        width: 40px; height: 40px;
        background: linear-gradient(135deg, #f59e0b, #d97706);
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-size: 1.1rem;
        box-shadow: 0 4px 12px rgba(245,158,11,.35);
    }

    .form-card {
        background: #fff; border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,.07);
        border: 1px solid #e2e8f0; overflow: hidden; max-width: 680px;
    }
    .form-card-header {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        padding: 1.25rem 1.75rem;
        display: flex; align-items: center; gap: .75rem; color: #fff;
    }
    .form-card-header .header-icon {
        width: 36px; height: 36px;
        background: rgba(245,158,11,.3);
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem;
        border: 1px solid rgba(245,158,11,.4);
    }
    .form-card-header h2 { font-size: 1rem; font-weight: 600; margin: 0; }
    .form-card-header p  { font-size: .78rem; margin: 0; color: rgba(255,255,255,.6); }
    .form-card-body { padding: 1.75rem; }

    .field-group { margin-bottom: 1.25rem; }
    .field-label {
        font-size: .8rem; font-weight: 600; color: #374151;
        margin-bottom: .4rem; display: flex; align-items: center;
        gap: .35rem; text-transform: uppercase; letter-spacing: .04em;
    }
    .field-label i { color: #6366f1; }
    .form-control {
        border: 1.5px solid #e2e8f0; border-radius: 8px;
        font-size: .88rem; padding: .55rem .85rem;
        transition: border-color .2s, box-shadow .2s; color: #0f172a;
    }
    .form-control:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.12); }
    textarea.form-control { resize: vertical; min-height: 100px; }

    .check-row {
        display: flex; align-items: center; gap: .75rem;
        background: #f8fafc; border: 1.5px solid #e2e8f0;
        border-radius: 10px; padding: .75rem 1rem;
    }
    .form-check-input { width: 1.15rem; height: 1.15rem; cursor: pointer; accent-color: #6366f1; }
    .check-row label { font-size: .88rem; font-weight: 500; color: #374151; cursor: pointer; margin: 0; }

    /* Meta info strip */
    .meta-strip {
        background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px;
        padding: .75rem 1rem; display: flex; gap: 1.5rem; flex-wrap: wrap;
        margin-bottom: 1.25rem;
    }
    .meta-item { font-size: .8rem; color: #64748b; display: flex; align-items: center; gap: .35rem; }
    .meta-item i { color: #94a3b8; }
    .meta-item strong { color: #334155; font-weight: 600; }

    .badge-status { font-size: .72rem; font-weight: 700; padding: .25rem .55rem; border-radius: 20px; }
    .badge-completed { background: #dcfce7; color: #166534; }
    .badge-active    { background: #fef3c7; color: #92400e; }
    .badge-overdue   { background: #fee2e2; color: #991b1b; }

    .form-card-footer {
        background: #f8fafc; border-top: 1px solid #e2e8f0;
        padding: 1.1rem 1.75rem; display: flex;
        align-items: center; gap: .75rem; flex-wrap: wrap;
    }
    .btn-submit {
        background: linear-gradient(135deg, #f59e0b, #d97706); color: #fff;
        border: none; border-radius: 8px; padding: .55rem 1.4rem;
        font-size: .88rem; font-weight: 600;
        display: inline-flex; align-items: center; gap: .4rem;
        cursor: pointer; transition: all .2s;
        box-shadow: 0 2px 8px rgba(245,158,11,.35);
    }
    .btn-submit:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(245,158,11,.45); }
    .btn-back {
        background: transparent; color: #64748b;
        border: 1.5px solid #e2e8f0; border-radius: 8px;
        padding: .5rem 1.2rem; font-size: .88rem; font-weight: 500;
        text-decoration: none; display: inline-flex;
        align-items: center; gap: .4rem; transition: all .18s;
    }
    .btn-back:hover { background: #f1f5f9; color: #374151; border-color: #cbd5e1; }
    .btn-del {
        background: transparent; color: #dc2626;
        border: 1.5px solid #fca5a5; border-radius: 8px;
        padding: .5rem 1.2rem; font-size: .88rem; font-weight: 500;
        text-decoration: none; display: inline-flex;
        align-items: center; gap: .4rem; transition: all .18s;
        margin-left: auto;
    }
    .btn-del:hover { background: #fff5f5; color: #b91c1c; }

    .validation-msg { font-size: .78rem; color: #dc2626; margin-top: .3rem; display: flex; align-items: center; gap: .25rem; }
</style>

<!-- Header -->
<div class="form-page-header">
    <div>
        <div class="breadcrumb-nav mb-1">
            <a asp-action="Index"><i class="bi bi-list-task"></i> All Tasks</a>
            <i class="bi bi-chevron-right"></i>
            <span>Edit</span>
        </div>
        <div class="page-title-row">
            <h1>
                <span class="title-icon"><i class="bi bi-pencil-square"></i></span>
                Edit Task
            </h1>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn-back"><i class="bi bi-eye"></i> View</a>
        <a asp-action="Index" class="btn-back"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<!-- Form Card -->
<div class="form-card">
    <div class="form-card-header">
        <div class="header-icon"><i class="bi bi-pencil"></i></div>
        <div>
            <h2>Editing: @Model.Title</h2>
            <p>Update the task fields and save your changes.</p>
        </div>
    </div>

    <form asp-action="Edit">
        <div class="form-card-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 px-3 mb-3" style="font-size:.82rem; border-radius:8px;"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />

            <!-- Meta strip -->
            <div class="meta-strip">
                <div class="meta-item"><i class="bi bi-hash"></i> ID: <strong>@Model.Id</strong></div>
                <div class="meta-item"><i class="bi bi-calendar-plus"></i> Created: <strong>@Model.CreatedAt.ToString("MMM dd, yyyy")</strong></div>
                <div class="meta-item"><i class="bi bi-circle-half"></i> Status:
                    @if (Model.IsCompleted)
                    {
                        <span class="badge-status badge-completed">Completed</span>
                    }
                    else if (isOverdue)
                    {
                        <span class="badge-status badge-overdue">Overdue</span>
                    }
                    else
                    {
                        <span class="badge-status badge-active">Active</span>
                    }
                </div>
            </div>

            <!-- Title -->
            <div class="field-group">
                <label asp-for="Title" class="field-label"><i class="bi bi-card-heading"></i> Title <span style="color:#ef4444">*</span></label>
                <input asp-for="Title" class="form-control" placeholder="Enter task title…" />
                <div asp-validation-for="Title" class="validation-msg"><i class="bi bi-exclamation-circle"></i></div>
            </div>

            <!-- Description -->
            <div class="field-group">
                <label asp-for="Description" class="field-label"><i class="bi bi-text-left"></i> Description</label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Add a description…"></textarea>
                <div asp-validation-for="Description" class="validation-msg"><i class="bi bi-exclamation-circle"></i></div>
            </div>

            <!-- Due Date -->
            <div class="field-group">
                <label asp-for="DueDate" class="field-label"><i class="bi bi-calendar-event"></i> Due Date</label>
                <input asp-for="DueDate" type="date" class="form-control" />
                <div asp-validation-for="DueDate" class="validation-msg"><i class="bi bi-exclamation-circle"></i></div>
            </div>

            <!-- Is Completed -->
            <div class="field-group mb-0">
                <label class="field-label"><i class="bi bi-circle-half"></i> Status</label>
                <div class="check-row">
                    <input asp-for="IsCompleted" class="form-check-input" id="IsCompleted" />
                    <label for="IsCompleted">Mark as Completed</label>
                </div>
                <div asp-validation-for="IsCompleted" class="validation-msg"><i class="bi bi-exclamation-circle"></i></div>
            </div>
        </div>

        <!-- Footer actions -->
        <div class="form-card-footer">
            <button type="submit" class="btn-submit"><i class="bi bi-check-lg"></i> Save Changes</button>
            <a asp-action="Index" class="btn-back"><i class="bi bi-x-lg"></i> Cancel</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-del"><i class="bi bi-trash"></i> Delete</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
