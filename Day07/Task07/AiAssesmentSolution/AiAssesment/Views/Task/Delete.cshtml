@model AiAssesment.Domain.Entities.TaskItem

@{
    ViewData["Title"] = "Delete Task";
    bool isOverdue = !Model.IsCompleted && Model.DueDate.HasValue && Model.DueDate.Value.Date < DateTime.Today;
}

<style>
    .form-page-header {
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem;
    }
    .breadcrumb-nav { font-size: .82rem; color: #64748b; display: flex; align-items: center; gap: .4rem; }
    .breadcrumb-nav a { color: #6366f1; text-decoration: none; }
    .breadcrumb-nav a:hover { text-decoration: underline; }
    .page-title-row h1 {
        font-size: 1.5rem; font-weight: 700; color: #0f172a; margin: 0;
        display: flex; align-items: center; gap: .5rem;
    }
    .page-title-row h1 .title-icon {
        width: 40px; height: 40px;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-size: 1.1rem;
        box-shadow: 0 4px 12px rgba(239,68,68,.35);
    }

    /* Danger alert */
    .danger-banner {
        background: linear-gradient(135deg, #fef2f2, #fff5f5);
        border: 1.5px solid #fca5a5;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        display: flex; align-items: center; gap: .75rem;
        max-width: 680px;
    }
    .danger-banner .banner-icon {
        width: 42px; height: 42px; flex-shrink: 0;
        background: #fee2e2; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem; color: #dc2626;
    }
    .danger-banner h3 { font-size: .95rem; font-weight: 700; color: #991b1b; margin: 0; }
    .danger-banner p  { font-size: .82rem; color: #b91c1c; margin: .15rem 0 0; }

    /* Card */
    .delete-card {
        background: #fff; border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,.07);
        border: 1px solid #e2e8f0; overflow: hidden; max-width: 680px;
    }
    .delete-card-header {
        background: linear-gradient(135deg, #7f1d1d 0%, #991b1b 100%);
        padding: 1.25rem 1.75rem;
        display: flex; align-items: center; gap: .75rem; color: #fff;
    }
    .delete-card-header .header-icon {
        width: 36px; height: 36px;
        background: rgba(255,255,255,.15);
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem;
        border: 1px solid rgba(255,255,255,.2);
    }
    .delete-card-header h2 { font-size: 1rem; font-weight: 600; margin: 0; }
    .delete-card-header p  { font-size: .78rem; margin: 0; color: rgba(255,255,255,.65); }

    .delete-card-body { padding: 1.75rem; }

    .detail-row {
        display: flex; gap: 1rem; margin-bottom: 1.25rem;
        padding-bottom: 1.25rem; border-bottom: 1px solid #f1f5f9;
    }
    .detail-row:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .detail-icon {
        width: 36px; height: 36px; flex-shrink: 0;
        background: #fff5f5; border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        color: #ef4444; font-size: .9rem;
    }
    .detail-label { font-size: .75rem; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: .05em; margin-bottom: .15rem; }
    .detail-value { font-size: .92rem; color: #1e293b; font-weight: 500; }
    .detail-value.text-empty { color: #cbd5e1; font-style: italic; font-weight: 400; }

    .badge-lg { font-size: .82rem; font-weight: 700; padding: .35rem .75rem; border-radius: 20px; display: inline-flex; align-items: center; gap: .35rem; }
    .badge-completed { background: #dcfce7; color: #166534; }
    .badge-active    { background: #fef3c7; color: #92400e; }
    .badge-overdue   { background: #fee2e2; color: #991b1b; }

    .delete-card-footer {
        background: #fef2f2; border-top: 1.5px solid #fca5a5;
        padding: 1.1rem 1.75rem;
        display: flex; align-items: center; gap: .75rem; flex-wrap: wrap;
    }
    .btn-delete {
        background: linear-gradient(135deg, #ef4444, #dc2626); color: #fff;
        border: none; border-radius: 8px; padding: .55rem 1.4rem;
        font-size: .88rem; font-weight: 600;
        display: inline-flex; align-items: center; gap: .4rem;
        cursor: pointer; transition: all .2s;
        box-shadow: 0 2px 8px rgba(239,68,68,.35);
    }
    .btn-delete:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(239,68,68,.45); }
    .btn-cancel {
        background: #fff; color: #374151;
        border: 1.5px solid #e2e8f0; border-radius: 8px;
        padding: .5rem 1.2rem; font-size: .88rem; font-weight: 500;
        text-decoration: none; display: inline-flex;
        align-items: center; gap: .4rem; transition: all .18s;
    }
    .btn-cancel:hover { background: #f1f5f9; border-color: #cbd5e1; color: #1e293b; }
</style>

<!-- Header -->
<div class="form-page-header">
    <div>
        <div class="breadcrumb-nav mb-1">
            <a asp-action="Index"><i class="bi bi-list-task"></i> All Tasks</a>
            <i class="bi bi-chevron-right"></i>
            <span>Delete</span>
        </div>
        <div class="page-title-row">
            <h1>
                <span class="title-icon"><i class="bi bi-trash"></i></span>
                Delete Task
            </h1>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn-cancel"><i class="bi bi-arrow-left"></i> Back to List</a>
    </div>
</div>

<!-- Danger Banner -->
<div class="danger-banner">
    <div class="banner-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
    <div>
        <h3>This action cannot be undone</h3>
        <p>You are about to permanently delete the task "<strong>@Model.Title</strong>". Please confirm you want to proceed.</p>
    </div>
</div>

<!-- Delete Card -->
<div class="delete-card">
    <div class="delete-card-header">
        <div class="header-icon"><i class="bi bi-trash"></i></div>
        <div>
            <h2>@Model.Title</h2>
            <p>Review the task details below before deleting.</p>
        </div>
    </div>

    <div class="delete-card-body">
        <!-- Title -->
        <div class="detail-row">
            <div class="detail-icon"><i class="bi bi-card-heading"></i></div>
            <div>
                <div class="detail-label">Title</div>
                <div class="detail-value">@Model.Title</div>
            </div>
        </div>

        <!-- Description -->
        <div class="detail-row">
            <div class="detail-icon"><i class="bi bi-text-left"></i></div>
            <div>
                <div class="detail-label">Description</div>
                <div class="detail-value @(string.IsNullOrEmpty(Model.Description) ? "text-empty" : "")">
                    @(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)
                </div>
            </div>
        </div>

        <!-- Status -->
        <div class="detail-row">
            <div class="detail-icon"><i class="bi bi-circle-half"></i></div>
            <div>
                <div class="detail-label">Status</div>
                <div>
                    @if (Model.IsCompleted)
                    {
                        <span class="badge-lg badge-completed"><i class="bi bi-check-circle-fill"></i> Completed</span>
                    }
                    else if (isOverdue)
                    {
                        <span class="badge-lg badge-overdue"><i class="bi bi-exclamation-triangle-fill"></i> Overdue</span>
                    }
                    else
                    {
                        <span class="badge-lg badge-active"><i class="bi bi-hourglass-split"></i> Active</span>
                    }
                </div>
            </div>
        </div>

        <!-- Created At -->
        <div class="detail-row">
            <div class="detail-icon"><i class="bi bi-calendar-plus"></i></div>
            <div>
                <div class="detail-label">Created At</div>
                <div class="detail-value">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
            </div>
        </div>

        <!-- Due Date -->
        <div class="detail-row">
            <div class="detail-icon"><i class="bi bi-calendar-event"></i></div>
            <div>
                <div class="detail-label">Due Date</div>
                @if (Model.DueDate.HasValue)
                {
                    <div class="detail-value">@Model.DueDate.Value.ToString("MMM dd, yyyy")</div>
                }
                else
                {
                    <div class="detail-value text-empty">No due date set.</div>
                }
            </div>
        </div>
    </div>

    <!-- Footer: Confirm / Cancel -->
    <div class="delete-card-footer">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn-delete"><i class="bi bi-trash-fill"></i> Yes, Delete Task</button>
        </form>
        <a asp-action="Index" class="btn-cancel"><i class="bi bi-x-lg"></i> Cancel</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-cancel" style="margin-left:auto;"><i class="bi bi-pencil"></i> Edit Instead</a>
    </div>
</div>
