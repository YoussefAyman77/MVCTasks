<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="AI Assessment Task Management System" />
    <title>@ViewData["Title"] - TaskBoard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AiAssesment.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --primary:    #6366f1;
            --primary-dk: #4f46e5;
            --success:    #22c55e;
            --warning:    #f59e0b;
            --danger:     #ef4444;
            --info:       #38bdf8;
            --dark-bg:    #0f172a;
            --dark-nav:   #1e293b;
            --surface:    #ffffff;
            --text-muted: #94a3b8;
            --border:     #e2e8f0;
            --radius:     12px;
            --shadow:     0 4px 24px rgba(99,102,241,.12);
        }
        * { font-family: 'Inter', sans-serif; }
        body {
            background: #f1f5f9;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            padding-bottom: 0;
        }

        /* ── HEADER / NAVBAR ── */
        header .navbar {
            background: linear-gradient(135deg, var(--dark-bg) 0%, var(--dark-nav) 100%) !important;
            border-bottom: 1px solid rgba(99,102,241,.3) !important;
            box-shadow: 0 2px 20px rgba(0,0,0,.4);
            padding: .75rem 1.5rem;
        }
        .navbar-brand {
            font-weight: 700;
            font-size: 1.3rem;
            color: #fff !important;
            display: flex;
            align-items: center;
            gap: .5rem;
            letter-spacing: -.3px;
        }
        .navbar-brand .brand-icon {
            width: 34px; height: 34px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dk));
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            color: #fff;
            box-shadow: 0 0 12px rgba(99,102,241,.5);
        }
        .nav-link {
            color: rgba(255,255,255,.7) !important;
            font-size: .875rem;
            font-weight: 500;
            padding: .45rem .75rem !important;
            border-radius: 6px;
            transition: all .2s;
        }
        .nav-link:hover, .nav-link.active-link {
            color: #fff !important;
            background: rgba(99,102,241,.25);
        }
        .nav-link i { margin-right: .35rem; }

        /* Task Quick Actions in Navbar */
        .navbar-task-actions .btn {
            font-size: .78rem;
            font-weight: 600;
            padding: .35rem .75rem;
            border-radius: 6px;
            transition: all .2s;
        }
        .btn-nav-create {
            background: linear-gradient(135deg, var(--primary), var(--primary-dk));
            color: #fff;
            border: none;
            box-shadow: 0 2px 8px rgba(99,102,241,.4);
        }
        .btn-nav-create:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(99,102,241,.5); color: #fff; }
        .btn-nav-filter {
            background: rgba(255,255,255,.08);
            color: rgba(255,255,255,.8);
            border: 1px solid rgba(255,255,255,.15);
        }
        .btn-nav-filter:hover { background: rgba(255,255,255,.15); color: #fff; }

        /* ── MAIN CONTENT ── */
        .main-wrapper {
            flex: 1;
            padding: 1.5rem 0 3rem;
        }

        /* ── FOOTER ── */
        footer.site-footer {
            background: var(--dark-nav);
            color: rgba(255,255,255,.55);
            font-size: .825rem;
            padding: 1.25rem 0;
            border-top: 1px solid rgba(99,102,241,.2);
        }
        footer.site-footer .footer-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: .5rem;
        }
        footer.site-footer .footer-links a {
            color: rgba(255,255,255,.5);
            text-decoration: none;
            margin-left: 1rem;
            transition: color .2s;
        }
        footer.site-footer .footer-links a:hover { color: var(--primary); }
        footer.site-footer .footer-task-links {
            display: flex;
            gap: .5rem;
            flex-wrap: wrap;
        }
        footer.site-footer .footer-task-links a {
            font-size: .78rem;
            color: rgba(255,255,255,.45);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: .25rem;
            padding: .2rem .5rem;
            border-radius: 4px;
            transition: all .2s;
        }
        footer.site-footer .footer-task-links a:hover {
            color: var(--primary);
            background: rgba(99,102,241,.1);
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container-fluid">
                <!-- Brand -->
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon"><i class="bi bi-check2-square"></i></span>
                    TaskBoard
                </a>

                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <!-- Left nav -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house"></i>Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Task" asp-action="Index">
                                <i class="bi bi-list-task"></i>All Tasks
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Task" asp-action="Filter" asp-route-isCompleted="false">
                                <i class="bi bi-hourglass-split"></i>Active
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Task" asp-action="Filter" asp-route-isCompleted="true">
                                <i class="bi bi-check-circle"></i>Completed
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Task" asp-action="Sorted">
                                <i class="bi bi-sort-down"></i>By Due Date
                            </a>
                        </li>
                    </ul>

                    <!-- Right: quick action -->
                    <div class="navbar-task-actions d-flex gap-2">
                        <a asp-controller="Task" asp-action="Create" class="btn btn-nav-create">
                            <i class="bi bi-plus-lg me-1"></i>New Task
                        </a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="main-wrapper">
        <div class="container">
            <main role="main" class="pb-2">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-inner">
                <span><i class="bi bi-check2-square me-1" style="color:var(--primary)"></i> &copy; 2026 TaskBoard &mdash; AI Assessment</span>

                <div class="footer-task-links">
                    <a asp-controller="Task" asp-action="Index"><i class="bi bi-list-task"></i>All Tasks</a>
                    <a asp-controller="Task" asp-action="Create"><i class="bi bi-plus-circle"></i>New Task</a>
                    <a asp-controller="Task" asp-action="Filter" asp-route-isCompleted="false"><i class="bi bi-hourglass-split"></i>Active</a>
                    <a asp-controller="Task" asp-action="Filter" asp-route-isCompleted="true"><i class="bi bi-check-circle"></i>Completed</a>
                    <a asp-controller="Task" asp-action="Sorted"><i class="bi bi-sort-down"></i>By Due Date</a>
                </div>

                <div class="footer-links">
                    <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
