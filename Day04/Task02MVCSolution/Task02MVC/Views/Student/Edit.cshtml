@model StudentAddEditVM

<h1>Edit</h1>
<form method="post" action="/Student/SaveEdit/@Model?.Id">
    <input type="hidden" name="Id" id="Id" value="@Model?.Id" class="form form-control" />
    <div>
        <label>Name</label>
        <input type="text" name="Name" id="Name" value="@Model?.Name" class="form form-control" />
    </div>
    <div>
        <label>Age</label>
        <input type="number" name="Age" id="Age" value="@Model?.Age" class="form form-control" />
    </div>

    <div>
        <label>Department</label>
        <select name="DepartmentId" class="form-control form">
            @foreach (var item in Model?.Departments)
            {
                @if (Model?.DepartmentId == item.Id)
                {
                    <option value="@item.Id" selected>@item.Name</option>
                }
                else
                {
                    <option value="@item.Id" >@item.Name</option>
                }

            }
        </select>
    </div>
    <input type="submit" value="Save" class="btn btn-primary mt-3 mb-3" />
</form>
