@model List<Student>

<h2>Students</h2>

<table border="2">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Age</th>
    </tr>

    @foreach (var s in Model)
    {
        <tr>
            <td>@s.Id</td>
            <td>@s.Name</td>
            <td>@s.Age</td>
        </tr>
    }
</table>